{
  "name": "forest-capture",
  "version": "3.1.0",
  "private": true,
  "description": "Forest Capture — wrap web assets for Android APK (Capacitor)",
  "scripts": {
    "start": "npx serve -l 8080",
    "prep": "node prep-www.js",
    "cap:sync": "node prep-www.js && cap sync android",
    "cap:open": "cap open android",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/analytics.test.js",
    "test:e2e": "jest --runInBand --config=jest-e2e.config.js"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/share": "^6.0.4",
    "firebase": "^12.11.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@capacitor/cli": "^6.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-puppeteer": "^11.0.0",
    "puppeteer": "^24.40.0",
    "serve": "^14.2.6",
    "sharp": "^0.34.5"
  }
}
