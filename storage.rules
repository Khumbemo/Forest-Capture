rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Owner-Only access: Users can only access files in their own folder.
    // Assuming files are stored as 'users/{userId}/...'
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
